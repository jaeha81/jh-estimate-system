# ================================================================
# JH-견적시스템 환경변수 설정
# 사용법: 이 파일을 복사해서 .env 로 저장 후 실제 값 입력
# 주의: .env 파일은 절대 git commit 하지 말 것 (.gitignore 확인)
# ================================================================

# ── Supabase ──────────────────────────────────────────────────
# Supabase Dashboard > Settings > API 에서 확인
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Claude API ────────────────────────────────────────────────
# https://console.anthropic.com > API Keys
CLAUDE_API_KEY=sk-ant-api03-your-key-here
CLAUDE_MODEL=claude-sonnet-4-6

# ── AI 분류 설정 ──────────────────────────────────────────────
# 이 값 미만이면 review_flag=true 자동 설정
CONFIDENCE_THRESHOLD=0.7

# ── 파일 업로드 설정 ──────────────────────────────────────────
MAX_UPLOAD_SIZE_MB=50
ALLOWED_EXTENSIONS=.xlsx,.xls,.pdf
SUPABASE_BUCKET=estimate-files

# ── Kakao Alimtalk (옵션) ────────────────────────────────────
# 카카오 비즈니스 > 알림톡 > 발신 프로파일 키
KAKAO_API_KEY=your-kakao-api-key-here
KAKAO_SENDER_KEY=your-sender-key-here
KAKAO_TEMPLATE_CONFIRM=confirm-template-code
KAKAO_TEMPLATE_DONE=done-template-code
KAKAO_TEMPLATE_ERROR=error-template-code

# ── 앱 설정 ──────────────────────────────────────────────────
APP_ENV=development
# development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,https://your-vercel-domain.vercel.app

# ── 데이터 보존 ───────────────────────────────────────────────
# 견적 파일 보존 기간 (일)
FILE_RETENTION_DAYS=30
